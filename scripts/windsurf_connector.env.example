# Copy this file to .windsurf_connector.env and update values.
# Keep this file private and do NOT commit real keys.

AISEC_CONNECTOR_KEY="replace_with_rotated_windsurf_connector_key"
AISEC_SOURCE="windsurf-ide"
AISEC_PROVIDER="openai"
AISEC_IDE_NAME="windsurf"
AISEC_LISTEN_HOST="127.0.0.1"
AISEC_LISTEN_PORT="8788"
AISEC_DEFAULT_MODEL="gpt-4o-mini"
AISEC_TIMEOUT_SEC="30"
AISEC_GATEWAY_URL="http://localhost:8000/gateway/process"

# Set to "1" if ngrok should be started with the helper.
ENABLE_NGROK="1"
NGROK_PORT="8788"

